<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<HBox prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: linear-gradient(to bottom right, #E4F2E7, #93BFB7);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="omr.uacm.sistemafitguide.PantallaDescansoController">

    <VBox alignment="CENTER" prefWidth="450.0" spacing="0.0" style="-fx-background-color: white; -fx-background-radius: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
        </padding>
        <children>

            <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="DESCANSA" VBox.vgrow="NEVER" />
            <Region prefHeight="18.0" />

            <StackPane maxHeight="220.0" maxWidth="220.0" prefHeight="220.0" prefWidth="220.0" VBox.vgrow="NEVER">
                <children>
                    <Circle fill="transparent" radius="100.0" stroke="#E0E0E0" strokeWidth="14.0" />
                    <Group>
                        <children>
                            <Circle fx:id="circuloProgreso" fill="transparent" radius="100.0" rotate="-90" stroke="#4CAF50" strokeWidth="14.0" />
                        </children>
                    </Group>
                    <Label fx:id="lblTiempo" style="-fx-font-size: 72px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="35" />
                </children>
            </StackPane>

            <Region prefHeight="10.0" />
            <Label style="-fx-font-size: 16px;" text="segundos" />
            <Region prefHeight="28.0" />

            <ProgressBar fx:id="barraProgreso" prefHeight="10.0" prefWidth="300.0" progress="1.0" style="-fx-accent: #4CAF50;" visible="false" managed="false" />
            <Region prefHeight="28.0" />

            <Label fx:id="lblMensaje" maxWidth="320.0" style="-fx-font-size: 16px;" text="¡Tómate un respiro, lo estás haciendo genial!" textAlignment="CENTER" wrapText="true" />
            <Region VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="16.0">
                <children>
                    <Button fx:id="btnPausar" onAction="#pausarReanudar" prefHeight="44.0" prefWidth="140.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 10;" text="Pausar">
                        <graphic>
                            <ImageView fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                                <image>
                                    <Image url="@imagenes/boton%20pausa%202.png" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <Button fx:id="btnSaltar" onAction="#saltarDescanso" prefHeight="44.0" prefWidth="140.0" style="-fx-background-color: #2D5A27; -fx-text-fill: white; -fx-background-radius: 10;" text="Saltar ➔" />
                </children>
            </HBox>

        </children>
        <HBox.margin>
            <Insets bottom="30.0" left="30.0" right="15.0" top="30.0" />
        </HBox.margin>
    </VBox>

    <VBox alignment="CENTER" prefWidth="450.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>
        <children>

            <StackPane maxHeight="200.0" maxWidth="260.0" prefHeight="200.0" prefWidth="260.0" style="-fx-background-color: #E0E0E0; -fx-background-radius: 15px;">
                <children>
                    <ImageView fx:id="imgSiguiente" fitHeight="200.0" fitWidth="260.0" pickOnBounds="true" StackPane.alignment="CENTER" />
                    
                    <Label style="-fx-background-color: #25AD76; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-padding: 3px 10px;" text="SIGUIENTE" StackPane.alignment="TOP_LEFT">
                        <StackPane.margin>
                            <Insets left="10.0" top="10.0" />
                        </StackPane.margin>
                    </Label>
                </children>
            </StackPane>

            <Label fx:id="lblSiguienteNombre" maxWidth="320.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Curl de Bíceps" textAlignment="CENTER" wrapText="true" />

            <HBox alignment="CENTER" spacing="30.0">
                <children>
                    <VBox fx:id="IbISeries" alignment="CENTER" spacing="4.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 14px 22px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                        <children>
                            <Label fx:id="lblSeries" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="2" />
                            <Label style="-fx-font-size: 14px;" text="series" />
                        </children>
                    </VBox>
                    <VBox fx:id="IbIreps" alignment="CENTER" spacing="4.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 14px 22px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                        <children>
                            <Label fx:id="lblReps" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="12" />
                            <Label style="-fx-font-size: 14px;" text="reps" />
                        </children>
                    </VBox>
                </children>
            </HBox>

            <Region prefHeight="35.0" prefWidth="327.0" VBox.vgrow="ALWAYS" />

            <VBox alignment="CENTER" spacing="8.0">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="6.0">
                        <children>
                            <Label style="-fx-font-size: 14px;" text="Progreso de la rutina" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="lblProgresoTexto" style="-fx-font-size: 14px;" text="2  / 10" />
                        </children>
                    </HBox>
                </children>
            </VBox>
            <ProgressBar fx:id="barraRutina" prefHeight="17.0" prefWidth="339.0" progress="1.0" style="-fx-accent: #25AD76;" />

        </children>
        <HBox.margin>
            <Insets bottom="30.0" left="15.0" right="30.0" top="30.0" />
        </HBox.margin>
    </VBox>
</HBox>