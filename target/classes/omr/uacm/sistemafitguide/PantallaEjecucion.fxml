<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: linear-gradient(to bottom right, #E4F2E7, #93BFB7); -fx-padding: 30;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="omr.uacm.sistemafitguide.PantallaEjecucionController">
    <children>

        <StackPane HBox.hgrow="ALWAYS" prefWidth="400.0">
            <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5);">
                <children>
                    <HBox alignment="CENTER" spacing="15.0">
                        <children>
                            <Label fx:id="lblNombreEjercicio" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2D3E40;" text="Cargando Ejercicio..." textAlignment="CENTER" wrapText="true" />
                            <Button fx:id="btnAyuda" mnemonicParsing="false" onAction="#mostrarInfoEjercicio" style="-fx-background-color: #387373; -fx-text-fill: white; -fx-background-radius: 50; -fx-font-weight: bold; -fx-cursor: hand;" text="¡" />
                        </children>
                    </HBox>
                    <ImageView fx:id="idmediaVideo" fitHeight="220.0" fitWidth="300.0" preserveRatio="true" />
                    <Label fx:id="lblInstrucciones" alignment="CENTER" style="-fx-background-color: #F4F4F4;-fx-padding: 15px;-fx-background-radius: 10px;-fx-border-color: #2F4F4F;-fx-border-width: 2px;-fx-border-radius: 8px;-fx-text-fill: #333333;" text="Mantén la espalda recta." wrapText="true">
                        <font>
                            <Font name="System Bold" size="16.0" />
                        </font>
                    </Label>
                </children>
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
            </VBox>

            <VBox fx:id="panelInfoEjercicio" alignment="CENTER" spacing="20.0" style="-fx-background-color: rgba(255, 255, 255, 0.95); -fx-background-radius: 20; -fx-border-color: #387373; -fx-border-width: 3; -fx-border-radius: 18;" visible="false">
                <children>
                    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2D3E40;" text="¿Qué músculos trabajas?" textAlignment="CENTER" />
                    <Label fx:id="lblInfoMensaje" style="-fx-font-size: 16px; -fx-text-fill: #333333;" text="..." textAlignment="CENTER" wrapText="true" />
                    <Button mnemonicParsing="false" onAction="#accionCerrarInfo" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="Entendido" />
                </children>
                <padding>
                    <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                </padding>
                <StackPane.margin>
                    <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                </StackPane.margin>
            </VBox>
        </StackPane>

        <VBox alignment="CENTER" prefWidth="350.0" spacing="40.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="TU OBJETIVO" />
                        <Label fx:id="lblMeta" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #387373;" text="Meta: -- Repeticiones" />
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #F8F9F9; -fx-background-radius: 15; -fx-border-color: #E5E7E9; -fx-border-radius: 15;">
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-text-fill: #2D3E40;" text="¿Cuántas hiciste realmente?" />
                        <TextField fx:id="txtRepeticionesReales" alignment="CENTER" maxWidth="150.0" promptText="Ej. 12" style="-fx-font-size: 20px; -fx-background-radius: 10; -fx-border-color: #93BFB7; -fx-border-radius: 10;" />
                    </children>
                    <padding>
                        <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
                    </padding>
                </VBox>

                <Button fx:id="btnSiguiente" mnemonicParsing="false" onAction="#registrarYContinuar" prefHeight="60.0" prefWidth="250.0" style="-fx-background-color: linear-gradient(to bottom, #387373, #2D3E40); -fx-text-fill: white; -fx-background-radius: 30; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 16px;" text="SIGUIENTE EJERCICIO ➔" />
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>

    </children>
</HBox>