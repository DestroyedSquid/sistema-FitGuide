<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: linear-gradient(to bottom right, #E4F2E7, #93BFB7);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="omr.uacm.sistemafitguide.PantallaListaEjerciciosController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="100.0" spacing="20.0" style="-fx-background-color: #66C15C;">
            <padding>
                <Insets left="15.0" right="15.0" />
            </padding>
            <children>
                <Button mnemonicParsing="false" onAction="#regresarMenu" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-cursor: hand; -fx-background-color: #C81609; -fx-background-radius: 15;" text="←" />
                
                <Label prefHeight="44.0" prefWidth="320.0" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Selecciona tu Entrenamiento" />
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Equipo:" />
                <ComboBox fx:id="comboEquipo" prefHeight="33.0" prefWidth="113.0" />
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Grupo:" />
                <ComboBox fx:id="comboNivel" prefWidth="110.0" style="-fx-font-size: 14px; -fx-background-radius: 5;" />
            </children>
        </HBox>

        <HBox alignment="CENTER" spacing="30.0" style="-fx-background-color: linear-gradient(to bottom right, #E4F2E7, #93BFB7);" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>

                <StackPane maxWidth="260.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                    <children>
                        <ImageView fitHeight="400.0" fitWidth="260.0" preserveRatio="false">
                            <image><Image url="@imagenes/hombrelagartijabrazo.jpeg" /></image>
                            <effect><GaussianBlur radius="5.0" /></effect>
                        </ImageView>
                        <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: rgba(0,0,0,0.4); -fx-background-radius: 15;">
                            <padding><Insets bottom="30.0" left="20.0" right="20.0" top="40.0" /></padding>
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="Brazo" />
                                <Label style="-fx-text-fill: white; -fx-font-size: 14px; -fx-text-alignment: center;" text="Desarrolla fuerza y volumen en bíceps y tríceps con rutinas enfocadas en el tren superior." wrapText="true" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#iniciarBrazo" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 15; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 15px;" text="¡Empezar!" />
                            </children>
                        </VBox>
                    </children>
                </StackPane>

                <StackPane maxWidth="260.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                    <children>
                        <ImageView fitHeight="400.0" fitWidth="260.0" preserveRatio="false">
                            <image><Image url="@imagenes/hombreabdominalesabdominal.jpeg" /></image>
                            <effect><GaussianBlur radius="5.0" /></effect>
                        </ImageView>
                        <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: rgba(0,0,0,0.4); -fx-background-radius: 15;">
                            <padding><Insets bottom="30.0" left="20.0" right="20.0" top="40.0" /></padding>
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="Abdomen" />
                                <Label style="-fx-text-fill: white; -fx-font-size: 14px; -fx-text-alignment: center;" text="Fortalece tu core, mejora tu postura y marca el área abdominal con alta intensidad." wrapText="true" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#iniciarAbdomen" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 15; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 15px;" text="¡Empezar!" />
                            </children>
                        </VBox>
                    </children>
                </StackPane>

                <StackPane maxWidth="260.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                    <children>
                        <ImageView fitHeight="400.0" fitWidth="260.0" preserveRatio="false">
                            <image><Image url="@imagenes/hombresentadillapierna.jpeg" /></image>
                            <effect><GaussianBlur radius="5.0" /></effect>
                        </ImageView>
                        <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: rgba(0,0,0,0.4); -fx-background-radius: 15;">
                            <padding><Insets bottom="30.0" left="20.0" right="20.0" top="40.0" /></padding>
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" text="Pierna" />
                                <Label style="-fx-text-fill: white; -fx-font-size: 14px; -fx-text-alignment: center;" text="Potencia el tren inferior. Trabaja cuádriceps, isquiotibiales y glúteos al máximo." wrapText="true" />
                                <Region VBox.vgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#iniciarPierna" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 15; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 15px;" text="¡Empezar!" />
                            </children>
                        </VBox>
                    </children>
                </StackPane>

            </children>
        </HBox>
    </children>
</VBox>
